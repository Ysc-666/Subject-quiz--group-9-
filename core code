<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8"/>
    <title>Subject Quiz</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial,sans-serif;
        }
        body{
            padding: 20px;
            max-width: 800px;
            margin:0 auto;
        }
        .nav{
            margin-bottom:30px;
            border-bottom: 1px solid #ddd;
            padding-bottom: 10px;
        }
        .nav button{
            padding: 8px 16px;
            margin-right: 10px;
            cursor: pointer;
            background-color: #f0f0f0;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        .nav button:hover{
            background-color: #e0e0e0;
        }
        .page{
            display: none;
        }
        .page.active{
            display: block;
        }
        #subject-list{
            margin: 20px 0;
            display:flex;
            flex-wrap:wrap;
            gap:10px;
        }
        .subject-card{
            padding: 10px 15px;
            background-color: #4CAF50;
            color:white;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .subject-card:hover{
            background-color: #45a049;
        }
        .delete-btn{
            background-color: #f44336;
            border: none;
            color: white;
            padding: 2px 6px;
            border-radius: 2px;
            cursor: pointer;
            font-size: 12px;
            margin-left: 5px;
        }
        .delete-btn{
            background-color: #d32f2f;
        }
        .form-group{
            margin: 15px 0;
        }
        .form-group label{
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }
        .form-group input,.form-group select{
            width:100%;
            max-width: 500px;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        #options-container{
            margin: 20px 0;
        }
        #options-container div{
            margin: 10px 0;
        }
        button.submit-btn{
            background-color: #2196F3;
            color: white;
            border:none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
        }
        button.submit-btn:hover {
            background-color: #0b7dda;
        }
        #result-page{
            margin-top: 20px;
        }
        .result-stats{
            font-size: 18px;
            margin:10px 0;
        }
        .wrong-questions-section{
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
        }
        .wrong-question-item{
            border:1px solid #ffebee;
            padding: 15px;
            margin: 10px 0;
            border-radius:4px;
            background-color: #ffebee;
        }
        .correct-answer{
            color: #4CAF50;
            font-weight: bold;
        }
        .your-answer{
            color: #f44336;
            font-weight: bold;
        }
        #manage-question-page{
            margin-top: 20px;
        }
        .question-item{
            border: 1px solid #ddd;
            padding: 15px;
            margin:10px 0;
            border-radius: 4px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .question-info{
            flex: 1;
        }
        .question-action{
            margin-left: 20px;
        }
    </style>
</head>
<body>
    <div class="nav">
    <button onclick="switchPage('quiz-home-page')">Homepage（答題主頁）</button>
    <button onclick="switchPage('create-subject-page')">Create(創建新學科)</button>
    <button onclick="switchPage('add-question-page')">Add（新增題目）</button>
    <button onclick="switchPage('manage-questions-page')">Management（管理題目/学科）</button>
    </div>
    
    
    <div id="quiz-home-page" class="page active">
        
        <h1>Subject Fun Quiz</h1>
        <h3>Select a Subject to Start</h3>
        <div id="subject-list"></div>
       
        <p id="no-subject-msg" style="color:#666;display:none;">No subject yet! Create a new subject first.</p> 
    </div>
    <div id="create-subject-page" class="page">
        <h1>Create New Subject</h1>
        <div class="form-group">
            <label for="new-subject-name">Subject Name (e.g. Physics,History):</label>
            <input type="text" id="new-subject-name" placeholder="Enter subject name">
        </div>
        <button onclick="createNewSubject()" class="submit-btn">Create Subject</button>
        <p id="create-msg" style="margin-top: 15px;"></p>
    </div>
    <div id="add-question-page" class="page">
        <h1>Add New Question</h1>
        <div class="form-group">
            <label for="question-subject">Select Subject:</label>
            <select id="question-subject">
                <option value="">-- Select a subject --</option>
            </select>
        </div>
        <div class="form-group">
            <label for="question-type">Question Type:</label>
            <select id="question-type">
                <option value="choice">Multiple Choice</option>
                <option value="judge">True/False</option>
            </select>
        </div>
        <div class="form-group">
            <label for="question-content">Question Content:</label>
            <input type="text" id="question-content" placeholder="Enter the question">
        </div>
        <div class="form-group">
            <label for="question-options">Options (split by comma, e.g. A,B,C,D or True,False):</label>
            <input type="text" id="question-options" placeholder="Enter options separated by commas">
        </div>
        <div class="form-group">
            <label for="question-answer">Correct Answer:</label>
            <input type="text" id="question-answer" placeholder="Enter the correct answer">
        </div>
        <button onclick="addNewQuestion()" class="submit-btn">Add Question</button>
        <p id="add-msg" style="margin-top: 15px;"></p>
    </div>
    <div id="quiz-page" class="page">
        <h2 id="question-title"></h2>
        <div id="options-container"></div>
        <button onclick="submitAnswer()" class="submit-btn">Submit Answer</button>
    </div>
    <div id="result-page" class="page">
        <h2>Quiz Result</h2>
        <p class="result-stats">Correct Answers: <span id="correct-count">0</span>/<span id="total-count">0</span></p>
        <p class="result-stats">Accuracy: <span id="accuracy">0</span>%</p>
        <div class="wrong-question-section">
            <h3>Wrong Question Review</h3>
            <div id="wrong-questions-list"></div>
            <p id="no-wrong-msg" style="color:#666;display:none;">Congratulations! No wrong answers!</p>
        </div>
        <button onclick="restartQuiz()" class="submit-btn" style="margin-top: 20px;">Back to Subject List</button>
    </div>
    <div id="manage-questions-page" class="page">
        <h1>Manage Subjects & Questions</h1>
        <div class="form-group">
            <h3>1. Manage Subjects</h3>
            <select id="manage-subject" onchange="loadSubjectQuestions()">
                <option value="">-- Select a subject to manage --</option>
            </select>
            <button onclick="deleteSelectedSubject()" class="delete-btn" style="margin-left:10px;">Delete Selected Subject</button>
        </div>

        <div class="form-group">
            <h3>2.Manage Questions (Selected Subject)</h3>
            <div id="manage-questions-list"></div>
            <p id="no-questions-msg" style="color:#666; display:none;">No questions in this subject yet!</p>
        </div>
    </div>
    <script>
        const dom = {
            subjectList: document.getElementById('subject-list'),
            noSubjectMsg: document.getElementById('no-subject-msg'),
            newSubjectName: document.getElementById('new-subject-name'),
            createMsg: document.getElementById('create-msg'),
            questionSubject: document.getElementById('question-subject'),
            questionType: document.getElementById('question-type'),
            questionContent: document.getElementById('question-content'),
            questionOptions: document.getElementById('question-options'),
            questionAnswer: document.getElementById('question-answer'),
            addMsg: document.getElementById('add-msg'),
            manageSubject: document.getElementById('manage-subject'),
            manageQuestionsList: document.getElementById('manage-questions-list'),
            noQuestionsMsg: document.getElementById('no-questions-msg'),
            questionTitle: document.getElementById('question-title'),
            optionsContainer: document.getElementById('options-container'),
            correctCount: document.getElementById('correct-count'),
            totalCount: document.getElementById('total-count'),
            accuracy: document.getElementById('accuracy'),
            wrongQuestionsList: document.getElementById('wrong-questions-list'),
            noWrongMsg: document.getElementById('no-wrong-msg')
        };
        let quizAppData = initData();

        let currentSubject = "";
        let currentQuestions = [];
        let currentQIndex = 0;
        let correctCount = 0;
        let answerRecords = [];
        function switchPage(pageId){
            document.querySelectorAll('.page').forEach(page => {
                page.classList.remove('active');
            });
            document.getElementById(pageId).classList.add('active');
            if (pageId === 'quiz-home-page'){
                
                if(typeof renderSubjectList === 'function') renderSubjectList();
            }
            if (pageId ==='add-question-page'){
                if (typeof updateSubjectSelect === 'function') updateSubjectSelect();
            }
            if (pageId === 'manage-questions-page'){
                if (typeof updateManageSubjectSelect === 'function') updateManageSubjectSelect();
                document.getElementById('manage-questions-list').innerHTML = "";
                document.getElementById('no-questions-msg').style.display="none";
            }
        }
       
        function initData() {
            const stored = localStorage.getItem('quizAppData');
            if (!stored) {
                const def = { subjects: [], questions: {} };
                localStorage.setItem('quizAppData', JSON.stringify(def));
                return def;
            }
            return JSON.parse(stored);
        }
        function saveData(data = quizAppData) {
            localStorage.setItem('quizAppData', JSON.stringify(data));
        }

        


        function validateSubjectName(subjectName) {
            if (!subjectName.trim()) {
            return { valid: false, message: "Please enter a subject name!", color: "red" };
        }
            if (quizAppData.subjects.includes(subjectName)) {
            return { valid: false, message: "This subject already exists!", color: "red" };
        }
        return { valid: true };
        }

        function createNewSubject() {
            const subjectName = document.getElementById('new-subject-name').value;
            const createMsg = document.getElementById('create-msg');
  
            const validation = validateSubjectName(subjectName);
            if (!validation.valid) {
                createMsg.textContent = validation.message;
                createMsg.style.color = validation.color;
                return;
            }
  
            quizAppData.subjects.push(subjectName);
            quizAppData.questions[subjectName] = [];
            saveData(quizAppData);
  
            createMsg.textContent = `Subject "${subjectName}" created successfully!`;
            createMsg.style.color = "green";
            document.getElementById('new-subject-name').value = "";
  
            updateUI();
        }

        function deleteSubject(subjectName) {
            if (!confirm(`Are you sure to delete "${subjectName}"? All questions will be deleted!`)) {
                return false;
            }
  
            quizAppData.subjects = quizAppData.subjects.filter(sub => sub !== subjectName);
            delete quizAppData.questions[subjectName];
            saveData(quizAppData);
  
            return true;
        }

        function deleteSubjectDirect(subjectName) {
            if (deleteSubject(subjectName)) {
                updateUI();
            }
        }

        function deleteSelectedSubject() {
            const subjectName = document.getElementById('manage-subject').value;
            if (!subjectName) {
                alert("Please select a subject to delete!");
                return;
            }
  
            if (deleteSubject(subjectName)) {
                alert(`Subject "${subjectName}" deleted!`);
                updateUI();
                clearQuestionList();
            }
        }

        function updateUI() {
            renderSubjectList();
            updateSubjectSelect();
            updateManageSubjectSelect();
        }

        function renderSubjectList() {
            const subjectList = document.getElementById('subject-list');
            const noSubjectMsg = document.getElementById('no-subject-msg');
  
            subjectList.innerHTML = "";
  
            if (quizAppData.subjects.length === 0) {
                noSubjectMsg.style.display = "block";
                return;
            }
  
            noSubjectMsg.style.display = "none";
  
            quizAppData.subjects.forEach(subject => {
                const subjectCard = createSubjectCard(subject);
                subjectList.appendChild(subjectCard);
            });
        }

        function createSubjectCard(subject) {
            const subjectCard = document.createElement('div');
            subjectCard.className = "subject-card";
            subjectCard.innerHTML = `
                <span>${subject}</span>
                <button class="delete-btn" onclick="event.stopPropagation(); deleteSubjectDirect('${subject}')">×</button>
            `;
            subjectCard.onclick = () => startQuiz(subject);
            return subjectCard;
        }

        function updateSubjectSelect() {
            updateSelect('question-subject', '-- Select a subject --');
        }

        function updateManageSubjectSelect() {
            updateSelect('manage-subject', '-- Select a subject to manage --');
        }

        function updateSelect(selectId, placeholderText) {
            const select = document.getElementById(selectId);
            select.innerHTML = `<option value="">${placeholderText}</option>`;
  
            quizAppData.subjects.forEach(subject => {
                const option = document.createElement('option');
                option.value = subject;
                option.textContent = subject;
                select.appendChild(option);
            });
        }

        function clearQuestionList() {
            document.getElementById('manage-questions-list').innerHTML = "";
            document.getElementById('no-questions-msg').style.display = "none";
        }
    
        function addNewQuestion() {
            const subject = document.getElementById('question-subject').value;
            const type = dom.questionType.value;
            const content = dom.questionContent.value.trim();
            const optionsStr = dom.questionOptions.value.trim();
            const answer = dom.questionAnswer.value.trim();

            if (!subject || !content || !optionsStr || !answer) {
                dom.addMsg.textContent = 'Fill all fields!';
                dom.addMsg.style.color = 'red';
                return;
            }

            const options = optionsStr.split(',').map(o => o.trim());
            if (options.length < 2) {
                dom.addMsg.textContent = 'At least 2 options!';
                dom.addMsg.style.color = 'red';
                return;
            }
            if (!options.includes(answer)) {
                dom.addMsg.textContent = 'Answer not in options!';
                dom.addMsg.style.color = 'red';
                return;
            }

            const q = {
                id: Date.now(),
                type,
                content,
                options,
                answer
            };

            quizAppData.questions[subject].push(q);
            saveData();
            dom.addMsg.textContent = 'Added successfully!';
            dom.addMsg.style.color = 'green';
            dom.questionContent.value = '';
            dom.questionOptions.value = '';
            dom.questionAnswer.value = '';
        }


        function loadSubjectQuestions() {
            const subject = dom.manageSubject.value;
            dom.manageQuestionsList.innerHTML = '';
            dom.noQuestionsMsg.style.display = 'none';
            if (!subject) return;

            const qs = quizAppData.questions[subject] || [];
            if (qs.length === 0) {
                dom.noQuestionsMsg.style.display = 'block';
                return;
            }

            let html = '';
            qs.forEach(q => {
                const typeText = q.type === 'choice' ? 'Choice' : 'True/False';
                html += `
                <div class="question-item">
                    <div>
                        <strong>${typeText}:</strong> ${q.content}<br>
                        <small>Options: ${q.options.join(', ')} | Answer: ${q.answer}</small>
                    </div>
                    <button class="delete-btn" onclick="deleteQuestion('${subject}', ${q.id})">Delete</button>
                </div>`;
            });
            dom.manageQuestionsList.innerHTML = html;
        }

        function deleteQuestion(subject, id) {
            if (!confirm('Delete?')) return;
            quizAppData.questions[subject] = quizAppData.questions[subject].filter(q => q.id !== id);
            saveData();
            loadSubjectQuestions();
        }
        function startQuiz(subject) {
            currentSubject = subject;
            currentQuestions = quizAppData.questions[subject] || [];

            if (currentQuestions.length === 0) {
                alert(`No questions in "${subject}" yet! Please add questions first.`);
                return;
            }
            currentQuestions = [...currentQuestions].sort(() => Math.random() - 0.5);
  
            currentQIndex = 0;
            correctCount = 0;
            answerRecords = [];

            switchPage('quiz-page');
            showQuestion();
        }
        function showQuestion() {
            const question = currentQuestions[currentQIndex];
            document.getElementById('question-title').innerHTML = `
                <small style="color:#666; font-size:0.9em;">Question ${currentQIndex + 1} / ${currentQuestions.length}</small><br>
                ${question.content}
            `;

            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = "";

            question.options.forEach(option => {
                const div = document.createElement('div');
                div.style.margin = '12px 0';
                div.innerHTML = `
                    <label style="cursor:pointer; font-size:1.05em;">
                        <input type="radio" name="answer" value="${option}" style="margin-right:8px;">
                        ${option}
                    </label>
                `;
                optionsContainer.appendChild(div);
            });
        }
        function submitAnswer() {
            const selectedOption = document.querySelector('input[name="answer"]:checked');
  
            if (!selectedOption) {
                alert("Please select an answer!");
                return;
            }

            const currentQ = currentQuestions[currentQIndex];
            const isCorrect = selectedOption.value === currentQ.answer;

            if (isCorrect) correctCount++;
            answerRecords.push({
                question: currentQ,
                yourAnswer: selectedOption.value,
                isCorrect: isCorrect
            });

            currentQIndex++;

            if (currentQIndex < currentQuestions.length) {
                showQuestion();
            } else {
                showResult();
            }
        }
        
        function showResult() {
            const total = currentQuestions.length;
            const accuracy = Math.round((correctCount / total) * 100);

            document.getElementById('correct-count').textContent = correctCount;
            document.getElementById('total-count').textContent = total;
            document.getElementById('accuracy').textContent = accuracy;

            const wrongQuestionsList = document.getElementById('wrong-questions-list');
            const noWrongMsg = document.getElementById('no-wrong-msg');
            wrongQuestionsList.innerHTML = "";

            const wrongQuestions = answerRecords.filter(record => !record.isCorrect);
  
            if (wrongQuestions.length === 0) {
                noWrongMsg.style.display = "block";
            } else {
                noWrongMsg.style.display = "none";
                wrongQuestions.forEach((record, index) => {
                    const wrongItem = document.createElement('div');
                    wrongItem.className = "wrong-question-item";
                    wrongItem.innerHTML = `
                        <h4>Wrong Question ${index + 1}</h4>
                        <p><strong>Question:</strong> ${record.question.content}</p>
                        <p><strong>Your Answer:</strong> <span class="your-answer">${record.yourAnswer}</span></p>
                        <p><strong>Correct Answer:</strong> <span class="correct-answer">${record.question.answer}</span></p>
                    `;
                    wrongQuestionsList.appendChild(wrongItem);
                });
            }

            document.getElementById('quiz-page').classList.remove('active');
            document.getElementById('result-page').classList.add('active');
        }
        function restartQuiz() {
 
            currentSubject = "";
            currentQuestions = [];
            currentQIndex = 0;
            correctCount = 0;
            answerRecords = [];
  
            switchPage('quiz-home-page');
}

        window.onload = function(){
            if (typeof initData === 'function'){
                quizAppData = initData();
            }

            if (typeof updateSubjectList === 'function'){
                updateSubjectList();
            }
            if (typeof renderSubjectSelect === 'function'){
                renderSubjectSelect();
            }
            if (typeof updateManageSubjectSelect === 'function'){
                updateManageSubjectSelect();
            }
            quizAppData = initData();
            updateUI();
            switchPage('quiz-home-page')
        }
    </script>
</body>
</html>
